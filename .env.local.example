# Firebase web config (eduing-platform project)
# These are public/client-exposed by Firebase's design — see:
# https://firebase.google.com/docs/projects/api-keys
# Security is enforced via firestore.rules / storage.rules, not by hiding these.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=eduing-platform.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=eduing-platform
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=eduing-platform.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=475439810258
NEXT_PUBLIC_FIREBASE_APP_ID=
